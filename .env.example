# Copy to .env.local — NEXT_PUBLIC_* is exposed to the browser (same keys as old VITE_*)

# Canonical site URL for SEO, Open Graph, and metadata (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:8080

# Contact page mailto + copy (defaults to hello@trndinn.com if unset)
NEXT_PUBLIC_CONTACT_EMAIL=

NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_PROJECT_ID=

# ============================================
# POLAR PAYMENT CONFIGURATION
# ============================================
NEXT_PUBLIC_BILLING_PROVIDER=polar

NEXT_PUBLIC_POLAR_MODE=sandbox
NEXT_PUBLIC_POLAR_ORGANIZATION=trndinn

# Checkout Links - Live checkout URLs from Polar
# Standard Plan
NEXT_PUBLIC_POLAR_CHECKOUT_STANDARD_MONTHLY=https://sandbox.polar.sh/checkout/polar_c_QDM59G7UcRk0x04adkuniQ01oz7vDKXVpr0Y71MXNti
NEXT_PUBLIC_POLAR_CHECKOUT_STANDARD_YEARLY=https://sandbox.polar.sh/checkout/polar_c_WRAvUgs0Uk1Jy9zpfCUOBqsNtMsP3XGKocUdz16bIKz

# Pro Plan
NEXT_PUBLIC_POLAR_CHECKOUT_PRO_MONTHLY=https://sandbox.polar.sh/checkout/polar_c_eKlHVcf8FQijc9tTXqcFerPy3Kjnr4edySM6H2TNuhs
NEXT_PUBLIC_POLAR_CHECKOUT_PRO_YEARLY=https://sandbox.polar.sh/checkout/polar_c_ziQhoG1Pyet5oOMmajTEa5Tw7UR3XX33KtxVR2IHkOd

# Ultimate Plan
NEXT_PUBLIC_POLAR_CHECKOUT_ULTIMATE_MONTHLY=https://sandbox.polar.sh/checkout/polar_c_HwkGIpXmq4kjtXzVHgFpkD2SgurTISYgGvP8W03p9UH
NEXT_PUBLIC_POLAR_CHECKOUT_ULTIMATE_YEARLY=https://sandbox.polar.sh/checkout/polar_c_ZAN7Um21zwqVgXVyjd3OtAEUWjX95JbHTRsN22XGW5Z

# Price IDs for SDK-based checkout
# Standard Plan
NEXT_PUBLIC_POLAR_PRICE_STANDARD_MONTHLY=1a872740-b6ed-4624-ba6d-0f6d4597257e
NEXT_PUBLIC_POLAR_PRICE_STANDARD_YEARLY=2f5343ec-872c-4e40-b72c-2f9666639b80

# Pro Plan
NEXT_PUBLIC_POLAR_PRICE_PRO_MONTHLY=19fde135-18f0-4822-9014-d26d577b17ac
NEXT_PUBLIC_POLAR_PRICE_PRO_YEARLY=d3679bd2-871f-4789-8613-4bec0706deda

# Ultimate Plan
NEXT_PUBLIC_POLAR_PRICE_ULTIMATE_MONTHLY=b2b8401d-42ac-439b-afd1-caa4f31ae9de
NEXT_PUBLIC_POLAR_PRICE_ULTIMATE_YEARLY=219b6baa-e991-4921-ab07-b25124c09d96

# Supabase Edge / n8n (server-side; set in Supabase secrets for functions)
N8N_WEBHOOK_URL=

NEXT_PUBLIC_ADMIN_USER_ID=
NEXT_PUBLIC_ADMIN_EMAIL=

# PostHog (optional; omit key to disable). Self-host: see docs/env.posthog.example and docker/posthog/README.md
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=http://localhost

# Google Analytics (optional; omit to disable)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Set to 1 to enable verbose SSE debug logging in the browser console (disabled by default)
NEXT_PUBLIC_DEBUG_SSE=
